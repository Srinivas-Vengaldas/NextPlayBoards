# Local: copy to `.env` at repo root (Prisma / tooling) and `apps/web/.env` (Vite).
# Vercel: add the same variables in Project → Settings → Environment Variables
# (Production / Preview / Development as needed). Do not commit real secrets.

# Prisma + serverless API (`/api` on Vercel)
DATABASE_URL=
# Required for Prisma CLI (generate/migrate): Supabase *direct* Postgres (port 5432), not the pooler.
# Runtime queries still use DATABASE_URL (pooler 6543 + ?pgbouncer=true is typical on Vercel).
DIRECT_URL=
SUPABASE_JWT_SECRET=

# Vite app (`apps/web`) — exposed to the browser (use anon key only, never service role)
VITE_API_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
