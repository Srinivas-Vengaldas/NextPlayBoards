# Local: copy to `.env` at repo root (Prisma / `pnpm prisma:db-push`) and `apps/web/.env` (Vite).
# Prisma only loads the root `.env`, not `apps/web/.env`.
# Vercel: add the same variables in Project → Settings → Environment Variables
# (Production / Preview / Development as needed). Do not commit real secrets.

# Prisma + serverless API (`/api` on Vercel)
# Change from this:
# DATABASE_URL="postgresql://postgres...:6543/postgres?pgbouncer=true"


DATABASE_URL="postgresql://postgres.wfpzcfevypgrmprnixnx:CIT5RyFRxX1TUHQb@aws-1-us-east-2.pooler.supabase.com:5432/postgres" 
DIRECT_URL="postgresql://postgres.wfpzcfevypgrmprnixnx:CIT5RyFRxX1TUHQb@aws-1-us-east-2.pooler.supabase.com:5432/postgres"
