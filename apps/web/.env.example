# Copy to `apps/web/.env` for local dev. For Vercel, set these in the dashboard (same names).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Use same-origin `/api` so Preview and Production each call their own deployment (never hardcode another env’s URL).
# Omit or set to `/api`. For a standalone API during local dev only, you may use e.g. `http://localhost:8080` if your server exposes `/boards` at the root (see client base URL logic in `src/lib/api.ts`).
VITE_API_URL=/api
