{
  "name": "nextplay",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev:web": "pnpm --filter @nextplay/web dev",
    "dev:mobile": "pnpm --filter @nextplay/mobile start",
    "build:web": "pnpm --filter @nextplay/web build",
    "build:shared": "pnpm --filter @nextplay/shared build",
    "lint:web": "pnpm --filter @nextplay/web lint",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "prisma:db-push": "prisma db push",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:vercel-build": "prisma generate",
    "prisma:vercel-build:with-migrate": "prisma generate && prisma migrate deploy"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/node": "^5.6.22",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.1.0",
    "prisma": "^5.22.0"
  }
}
